# .env.example — template showing required env variables. Copy to .env and fill in.

# LLM / Embeddings
OPENAI_API_KEY=your_openai_key_here
EMBEDDING_MODEL=text-embedding-3-small
MODEL_NAME=gpt-4o
# Embedding provider: openai | local | auto (auto = OpenAI, fall back to local if key fails)
EMBEDDING_PROVIDER=auto
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=student_notes

# MCP Server
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8000

# Retrieval
RETRIEVAL_TOP_K=5
# Retrieval mode: hybrid (dense + BM25 + rerank) | dense (vector only)
RETRIEVAL_MODE=hybrid
RETRIEVAL_CANDIDATE_K=20
RERANK_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# leave empty to keep all top_k results; set a number to drop low-relevance results
RERANK_MIN_SCORE=
# 0 keeps every chunk; raise it to drop tiny fragments
MIN_CHUNK_CHARS=0

# Lecture audio/video transcription (ASR)
ASR_PROVIDER=local
ASR_MODEL=base
VIDEO_ENABLED=false
GROQ_API_KEY=

# Document parsing + chunking (Docling)
# Chunking strategy: hybrid (structure-aware, default) | semantic (embedding-similarity, opt-in)
CHUNK_MODE=hybrid
CHUNK_MAX_TOKENS=512
# OCR for scanned/handwritten PDFs and images (free, local, no API key)
DOCLING_DO_OCR=true
# OCR engine: rapidocr (default) | easyocr | tesseract
DOCLING_OCR_ENGINE=rapidocr
# Image-region area fraction that triggers region OCR (lower = more figures OCR'd, slower)
DOCLING_BITMAP_AREA_THRESHOLD=0.05
# Semantic chunking only: adjacent units merge while cosine similarity stays >= this
SEMANTIC_SIM_THRESHOLD=0.5

# Session
# Binds this process to one session; each session_id gets its own private store
SESSION_ID=default
SESSION_RESET_ON_START=true

# UI
UI_PORT=8501
